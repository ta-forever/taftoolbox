<!--
  Generated by CMake from taf-cpp-client.vcxproj.user.in — do not edit.
  Sets the VS debugger working directory to the executable output folder and
  injects the Qt DLL and plugin directories into the debug environment so Qt
  can be run directly from the Conan package cache without windeployqt.
  Passes the native-dir argument to the exe so external natives run from
  their own directory where their DLLs live.

  Qt bin dir   : @_qt_bin_dir_native@
  Qt plugins   : @_qt_plugins_dir_native@
  Native dir   : @_taf_natives_dir_native@
-->
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
