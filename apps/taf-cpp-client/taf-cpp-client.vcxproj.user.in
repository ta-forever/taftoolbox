    <LocalDebuggerWorkingDirectory>$(OutDir)</LocalDebuggerWorkingDirectory>
    <LocalDebuggerEnvironment>PATH=@_qt_bin_dir_native@;%PATH%
QT_PLUGIN_PATH=@_qt_plugins_dir_native@</LocalDebuggerEnvironment>
    <LocalDebuggerCommandArguments>@_native_dir_debugger_arg@</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
